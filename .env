# Опционально: настройки только для этого бота.
# Общие ключи (AI_API_KEY, API_TOKEN_INSTANCE, ID_INSTANCE, …) задавайте в корневом reilway/.env —
# они подхватываются автоматически и при совпадении имён перекрывают значения из bot/.env.

# Порт HTTP бота (иначе может взяться PORT=3000 от основного сервиса в корне).
BOT_PORT=3002

SESSION_PATH=./.wwebjs_auth_general
WWEBJS_CLIENT_ID=general-ai-wabot
PROTOCOL_TIMEOUT_MS=180000

# При необходимости переопределить только здесь:
# AI_API_URL=...
# AI_MODEL=...
# BOT_SYSTEM_PROMPT=
